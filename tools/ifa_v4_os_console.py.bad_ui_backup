def _load_v3_odu_module():
    try:
        from language_v3.spec import odu as v3_odu
        return v3_odu
    except Exception:
        return None


def _normalize_odu_key(value) -> int | None:
    if isinstance(value, int):
        if 0 <= value <= 15:
            return value
        return None

    if isinstance(value, str):
        cleaned = value.strip().replace("_", "").replace(" ", "")

        if len(cleaned) == 4 and set(cleaned) <= {"0", "1"}:
            return int(cleaned, 2)

        try:
            numeric = int(cleaned, 0)
        except ValueError:
            return None

        if 0 <= numeric <= 15:
            return numeric

    return None


def _discover_v3_odu_map() -> dict[int, str]:
    """
    Discover the real V3 binary-to-Odù mapping.

    This does not assume that the canonical name order is the same
    as the four-bit numeric order.
    """

    module = _load_v3_odu_module()

    if module is None:
        return {
            index: name
            for index, name in enumerate(FALLBACK_ODU_NAMES)
        }

    best_map: dict[int, str] = {}

    for attribute_name in dir(module):
        if attribute_name.startswith("_"):
            continue

        value = getattr(module, attribute_name)

        if not isinstance(value, dict):
            continue

        candidate: dict[int, str] = {}

        # Form 1:
        #     0b0000 -> "OGBÈ"
        #     "0000" -> "OGBÈ"
        for key, mapped_value in value.items():
            index = _normalize_odu_key(key)

            if index is not None and isinstance(mapped_value, str):
                candidate[index] = mapped_value

        if len(candidate) > len(best_map):
            best_map = candidate

        # Form 2:
        #     "OGBÈ" -> 0b0000
        #     "OGBÈ" -> "0000"
        inverted: dict[int, str] = {}

        for name, mapped_value in value.items():
            index = _normalize_odu_key(mapped_value)

            if index is not None and isinstance(name, str):
                inverted[index] = name

        if len(inverted) > len(best_map):
            best_map = inverted

    if len(best_map) == 16:
        return best_map

    # Search sequences of records such as:
    #     [("OGBÈ", "0000"), ...]
    for attribute_name in dir(module):
        if attribute_name.startswith("_"):
            continue

        value = getattr(module, attribute_name)

        if not isinstance(value, (list, tuple)):
            continue

        candidate: dict[int, str] = {}

        for item in value:
            if not isinstance(item, (list, tuple)) or len(item) < 2:
                continue

            first, second = item[0], item[1]

            first_index = _normalize_odu_key(first)
            second_index = _normalize_odu_key(second)

            if first_index is not None and isinstance(second, str):
                candidate[first_index] = second
            elif second_index is not None and isinstance(first, str):
                candidate[second_index] = first

        if len(candidate) > len(best_map):
            best_map = candidate

    if len(best_map) == 16:
        return best_map

    raise RuntimeError(
        "Could not discover the complete canonical V3 Odù mapping "
        "from language_v3.spec.odu."
    )


ODU_MAP = _discover_v3_odu_map()


def odu_name(value: int) -> str:
    return ODU_MAP[value & 0x0F]


def odu_bits(value: int) -> tuple[int, int, int, int]:
    """
    Return four Odù positions from top to bottom.

    0 renders as a single mark:  I
    1 renders as a double mark: II
    """

    nibble = value & 0x0F

    return tuple(
        (nibble >> shift) & 1
        for shift in (3, 2, 1, 0)
    )


def odu_mark(bit: int) -> str:
    return "II" if bit else "I"


def render_single_odu(
    value: int,
    heading: str = "ODÙ",
) -> None:
    bits = odu_bits(value)

    print()
    print(f"{heading}: {odu_name(value)}")
    print()

    for bit in bits:
        print(f"          {odu_mark(bit)}")

    print()
    print(f"Binary : {value & 0x0F:04b}")
    print(f"Index  : {value & 0x0F}")
    print()


def render_complete_odu(
    left_value: int,
    right_value: int,
    heading: str = "ODÙ IFÁ",
) -> None:
    left_bits = odu_bits(left_value)
    right_bits = odu_bits(right_value)

    print()
    print(f"{heading}")
    print()
    print("            LEFT        RIGHT")
    print()

    for left_bit, right_bit in zip(
        left_bits,
        right_bits,
    ):
        print(
            f"              "
            f"{odu_mark(left_bit):<8}"
            f"{odu_mark(right_bit)}"
        )

    print()
    print(
        f"Name   : "
        f"{odu_name(left_value)} "
        f"{odu_name(right_value)}"
    )
    print(
        f"Binary : "
        f"{left_value & 0x0F:04b} "
        f"{right_value & 0x0F:04b}"
    )
    print(
        f"Index  : "
        f"{left_value & 0x0F}:"
        f"{right_value & 0x0F}"
    )
    print()


def render_circular_cast(
    cast_value: int,
    cast_number: int,
) -> None:
    """
    Circular TẸ IFÁ presentation.

    ORÍ remains at the top centre.
    No rectangular border is used.
    """

    bits = odu_bits(cast_value)
    marks = [odu_mark(bit) for bit in bits]

    print()
    print("                         ORÍ")
    print("                          ●")
    print()
    print(
        f"                 {marks[0]:<8}"
        f"{marks[1]:>8}"
    )
    print()
    print("             ●                    ●")
    print()
    print(
        f"                 {marks[3]:<8}"
        f"{marks[2]:>8}"
    )
    print()
    print("                          ●")
    print()
    print(
        f"Cast {cast_number}: "
        f"{odu_name(cast_value)} "
        f"({cast_value & 0x0F:04b})"
    )
    print()


