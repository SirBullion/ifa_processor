LAST_TEIFA_ODU: tuple[int, int] | None = None


# Exact V3 PRINTODU nibble order.
#
# This is not YARA_REGISTRY order.
TEIFA_ODU_NAMES = (
    "ÒGBÈ",       # 0
    "ÒGÚNDÁ",     # 1
    "ÌRETẸ̀",      # 2
    "ÌRÒSÙN",     # 3
    "ÒTÚRÁ",      # 4
    "ÒṢÉ",        # 5
    "ÒDÍ",        # 6
    "ÒBÀRÀ",      # 7
    "ÒSÁ",        # 8
    "ÌWÒRÌ",      # 9
    "ÒFÚN",       # A
    "ÌKÁ",        # B
    "ÒWÓNRÍN",    # C
    "ÒTÚRÚPỌ̀N",  # D
    "ÒKÀNRÀN",    # E
    "ÒYÈKÚ",      # F
)


def normalize_odu_word(
    value: str,
) -> str:
    """
    Normalize accented and unaccented Odù spellings.

    Examples:
        ÒGBÈ       -> OGBE
        Ọ̀YẸ̀KÚ    -> OYEKU
        ÌRẸTẸ̀     -> IRETE
    """

    decomposed = unicodedata.normalize(
        "NFKD",
        value.strip().upper(),
    )

    return "".join(
        character
        for character in decomposed
        if (
            not unicodedata.combining(character)
            and character.isalnum()
        )
    )


TEIFA_ODU_LOOKUP = {
    normalize_odu_word(name): index
    for index, name in enumerate(
        TEIFA_ODU_NAMES
    )
}


# Common accepted variants.
TEIFA_ODU_ALIASES = {
    "OGBE": "OGBE",
    "OYEKU": "OYEKU",
    "IWORI": "IWORI",
    "ODI": "ODI",
    "IROSUN": "IROSUN",
    "OWONRIN": "OWONRIN",
    "OBARA": "OBARA",
    "OKANRAN": "OKANRAN",
    "OGUNDA": "OGUNDA",
    "OSA": "OSA",
    "IKA": "IKA",
    "OTURUPON": "OTURUPON",
    "OTURA": "OTURA",
    "IRETE": "IRETE",
    "OSE": "OSE",
    "OFUN": "OFUN",
}


def resolve_teifa_odu(
    value: str,
) -> int | None:
    normalized = normalize_odu_word(value)

    normalized = TEIFA_ODU_ALIASES.get(
        normalized,
        normalized,
    )

    return TEIFA_ODU_LOOKUP.get(
        normalized
    )


def render_teifa_odu(
    right_value: int,
    left_value: int,
) -> None:
    """
    Display one complete Odù entered through TẸ IFÁ.

    The first supplied Odù is Ọ̀TÚN.
    The second supplied Odù is ÒSÌ.
    """

    right_lines = odu_lines(
        right_value
    )

    left_lines = odu_lines(
        left_value
    )

    right_name = TEIFA_ODU_NAMES[
        right_value & 0x0F
    ]

    left_name = TEIFA_ODU_NAMES[
        left_value & 0x0F
    ]

    is_meji = right_value == left_value

    print()
    print("TẸ IFÁ")
    print("------")
    print()
    print("              Ọ̀TÚN            ÒSÌ")
    print()

    for right_mark, left_mark in zip(
        right_lines,
        left_lines,
    ):
        print(
            f"                "
            f"{right_mark:<16}"
            f"{left_mark}"
        )

    print()

    if is_meji:
        print(
            f"ODÙ    : {right_name} MÉJÌ"
        )
    else:
        print(
            f"ODÙ    : "
            f"{right_name} {left_name}"
        )

    print(
        f"Ọ̀TÚN   : "
        f"{right_name} "
        f"(0x{right_value:X})"
    )

    print(
        f"ÒSÌ    : "
        f"{left_name} "
        f"(0x{left_value:X})"
    )

    print(
        f"ÀMÌ    : "
        f"{right_value:04b} "
        f"{left_value:04b}"
    )

    print(
        f"ÀTỌ́KA : "
        f"{right_value}:"
        f"{left_value}"
    )

    print()


def teifa_from_names(
    arguments: list[str],
) -> None:
    """
    Understand one or two entered Odù names.

    One name:
        TEIFA OGBE
        -> ÒGBÈ MÉJÌ

    Two names:
        TEIFA OGBE OYEKU
        -> ÒGBÈ ÒYÈKÚ
    """

    global LAST_TEIFA_ODU

    if len(arguments) not in {
        1,
        2,
    }:
        print("Lo:")
        print("  TEIFA OGBE")
        print("  TEIFA OGBE OYEKU")
        print("  TẸ IFÁ ÒGBÈ ÒYÈKÚ")
        return

    right_value = resolve_teifa_odu(
        arguments[0]
    )

    if right_value is None:
        print(
            f"KÒ MỌ ODÙ: {arguments[0]}"
        )
        return

    if len(arguments) == 1:
        left_value = right_value
    else:
        left_value = resolve_teifa_odu(
            arguments[1]
        )

        if left_value is None:
            print(
                f"KÒ MỌ ODÙ: {arguments[1]}"
            )
            return

    LAST_TEIFA_ODU = (
        right_value,
        left_value,
    )

    render_teifa_odu(
        right_value,
        left_value,
    )


def print_last_teifa() -> None:
    if LAST_TEIFA_ODU is None:
        print(
            "KÒ SÍ ODÙ TẸ IFÁ TÍ A TI FI SÍLẸ̀."
        )
        return

    right_value, left_value = (
        LAST_TEIFA_ODU
    )

    render_teifa_odu(
        right_value,
        left_value,
    )


