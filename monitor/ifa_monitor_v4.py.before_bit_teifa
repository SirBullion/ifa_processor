    print(f"YÀTỌ̀    : 0x{result.rd:02X}")
    print(f"ÌPÌLẸ̀   : 0x{result.r0:02X}")
    print(f"GBÉ      : 0x{result.t:02X}")

    print(
        f"RMU      : "
        f"{'HIT' if result.hit else 'MISS'}"
    )

    print(f"VALID    : {result.valid}")

    print(
        f"EXC      : {result.exception} "
